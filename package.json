{
  "name": "i18n",
  "description": "lightweight translation module with dynamic json storage",
  "version": "0.15.3",
  "homepage": "https://github.com/mashpie/i18n-node",
  "repository": {
    "type": "git",
    "url": "https://github.com/mashpie/i18n-node.git"
  },
  "author": "Marcus Spiegel <marcus.spiegel@gmail.com>",
  "funding": {
    "url": "https://github.com/sponsors/mashpie"
  },
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "imports": {
    "#debug": "./lib/debug.js",
    "#i18n": "./index.js",
    "#package": "./package.json",
    "#printf": "./lib/printf.js",
    "#test-setup": "./test/node-test-setup.js"
  },
  "files": [
    "i18n.js",
    "index.js",
    "lib"
  ],
  "keywords": [
    "template",
    "i18n",
    "l10n"
  ],
  "directories": {
    "lib": "."
  },
  "dependencies": {
    "@messageformat/core": "^3.4.0",
    "make-plural": "^8.1.0",
    "math-interval-parser": "^2.0.1",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "cookie-parser": "^1.4.7",
    "eslint": "^10.1.0",
    "express": "^5.2.1",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bench": "npm --prefix ./bench run bench",
    "lint": "eslint .",
    "test": "node --test --test-concurrency=1 --import '#test-setup' ./test/i18n*.js",
    "test:coverage": "node --experimental-test-coverage --test --test-concurrency=1 --import '#test-setup' ./test/i18n*.js"
  },
  "license": "MIT",
  "packageManager": "npm@11.12.1"
}
